---
import {
  SITE_NAME,
  SITE_URL,
  MEDICO_NOMBRE,
  CONSULTORIO_ZONA,
  DEVELOPER_NAME,
  DEVELOPER_URL,
} from '../utils/constants';
import WhatsAppBtn from '../components/ui/WhatsAppBtn.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const DEFAULT_OG_IMAGE = '/images/og-image.jpg';
const ogImagePath = ogImage ?? DEFAULT_OG_IMAGE;
const ogImageURL = new URL(ogImagePath, SITE_URL).href;

function getOgImageType(path: string): string {
  const lowerPath = path.toLowerCase();
  if (lowerPath.endsWith('.png')) return 'image/png';
  if (lowerPath.endsWith('.jpg') || lowerPath.endsWith('.jpeg')) return 'image/jpeg';
  if (lowerPath.endsWith('.gif')) return 'image/gif';
  if (lowerPath.endsWith('.webp')) return 'image/webp';
  return 'image/jpeg';
}

const ogImageType = getOgImageType(ogImagePath);
const ogImageAlt = `${SITE_NAME} - ${title}`;

const schemaOrg = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: SITE_NAME,
  description: 'Consultas especializadas en salud masculina con el ' + MEDICO_NOMBRE,
  url: SITE_URL,
  telephone: '', // TODO: completar con WHATSAPP_NUMBER cuando el cliente lo provea
  address: {
    '@type': 'PostalAddress',
    addressLocality: CONSULTORIO_ZONA,
    addressCountry: 'AR',
  },
  areaServed: [
    { '@type': 'Country', name: 'Argentina' },
  ],
  availableService: [
    { '@type': 'MedicalTherapy', name: 'Disfunción Eréctil' },
    { '@type': 'MedicalTherapy', name: 'Eyaculación Precoz' },
    { '@type': 'MedicalTherapy', name: 'Falta de Deseo' },
    { '@type': 'MedicalTherapy', name: 'Terapia Hormonal con Pellets' },
    { '@type': 'MedicalTherapy', name: 'Urología Masculina' },
  ],
  hasMap: '',
  medicalSpecialty: 'Urology',
  creator: {
    '@type': 'Organization',
    name: DEVELOPER_NAME,
    url: DEVELOPER_URL,
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Título y descripción -->
    <title>{title} | {SITE_NAME}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts: preload de archivos críticos para reducir salto visual en primera carga -->
    <link
      rel="preload"
      href="/fonts/inter-v20-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/playfair-display-v40-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/playfair-display-v40-latin-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:secure_url" content={ogImageURL} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Schema.org MedicalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

    <!-- Slot para head adicional por página (meta robots, schema específico, etc.) -->
    <slot name="head" />
  </head>

  <body>
    <!-- Sitio desarrollado y creado por FrandoWeb https://frandoweb.com/ -->
    <slot />

    <!-- Botón flotante WhatsApp — presente en todas las páginas -->
    <WhatsAppBtn />
  </body>
</html>
