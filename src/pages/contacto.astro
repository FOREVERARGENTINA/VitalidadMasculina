---
import Page from '../layouts/Page.astro';
import VideoConsultaBanner from '../components/sections/VideoConsultaBanner.astro';
import { motivoOptions } from '../utils/contactSchema';
import { WHATSAPP_NUMBER, CONSULTORIO_ZONA } from '../utils/constants';

const whatsappHref = WHATSAPP_NUMBER
  ? `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent('Hola, quisiera solicitar un turno.')}`
  : '#';
---

<Page
  title="Contacto · Solicitá tu consulta"
  description={`Solicitá una consulta con el Dr. Leandro Mateu. Atención presencial en ${CONSULTORIO_ZONA} y por videollamada para toda Argentina.`}
>
  <section class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <ol>
          <li><a href="/">Inicio</a></li>
          <li aria-current="page">Contacto</li>
        </ol>
      </nav>
      <h1>Solicitá tu consulta</h1>
      <p class="page-hero__lead">
        Completá el formulario y te contactamos a la brevedad para coordinar un turno.
      </p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container contact-grid">

      <!-- Columna izquierda: info -->
      <aside class="contact-info">
        <h2>Modalidades de atención</h2>

        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <h3>Consulta presencial</h3>
            <p>Zona {CONSULTORIO_ZONA}</p>
            <p class="info-note">Solo atención particular</p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div>
            <h3>Videoconsulta</h3>
            <p>Para toda Argentina</p>
            <p class="info-note">Cómoda, privada y sin traslado</p>
          </div>
        </div>

        {WHATSAPP_NUMBER && (
          <div class="info-card">
            <div class="info-card__icon info-card__icon--wa" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <h3>WhatsApp</h3>
              <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="wa-link">
                Escribinos directo
              </a>
            </div>
          </div>
        )}

        <p class="contact-disclaimer">
          Este formulario no es un canal de urgencias. Para emergencias médicas llamá al 107.
        </p>
      </aside>

      <!-- Columna derecha: formulario -->
      <div class="contact-form-wrapper">

        <!-- Estado: éxito -->
        <div id="form-success" class="form-feedback form-feedback--success" hidden aria-live="polite">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <h3>¡Consulta enviada!</h3>
          <p>Recibimos tu mensaje. Te contactaremos a la brevedad para coordinar un turno.</p>
        </div>

        <!-- Estado: error de servidor -->
        <div id="form-error" class="form-feedback form-feedback--error" hidden aria-live="polite">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <h3>Error al enviar</h3>
          <p id="form-error-msg">Ocurrió un error. Por favor intentá de nuevo o escribinos por WhatsApp.</p>
        </div>

        <!-- Formulario -->
        <form id="contact-form" novalidate>
          <div class="form-row">
            <div class="field">
              <label for="nombre">Nombre <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                autocomplete="name"
                required
                aria-required="true"
                aria-describedby="error-nombre"
                placeholder="Tu nombre completo"
              />
              <span class="field-error" id="error-nombre" aria-live="polite"></span>
            </div>

            <div class="field">
              <label for="telefono">Teléfono <span aria-hidden="true">*</span></label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                autocomplete="tel"
                required
                aria-required="true"
                aria-describedby="error-telefono"
                placeholder="Ej: 11 1234-5678"
              />
              <span class="field-error" id="error-telefono" aria-live="polite"></span>
            </div>
          </div>

          <div class="field">
            <label for="email">Email <span aria-hidden="true">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              required
              aria-required="true"
              aria-describedby="error-email"
              placeholder="tu@email.com"
            />
            <span class="field-error" id="error-email" aria-live="polite"></span>
          </div>

          <div class="field">
            <label for="motivo">Motivo de consulta <span aria-hidden="true">*</span></label>
            <select
              id="motivo"
              name="motivo"
              required
              aria-required="true"
              aria-describedby="error-motivo"
            >
              <option value="" disabled selected>Seleccioná un motivo</option>
              {motivoOptions.map(m => <option value={m}>{m}</option>)}
            </select>
            <span class="field-error" id="error-motivo" aria-live="polite"></span>
          </div>

          <div class="field">
            <label for="mensaje">
              Mensaje <span aria-hidden="true">*</span>
              <span class="field-hint" id="hint-mensaje">Mínimo 10 caracteres</span>
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="5"
              required
              aria-required="true"
              aria-describedby="error-mensaje hint-mensaje"
              placeholder="Contanos brevemente tu consulta..."
            ></textarea>
            <span class="field-error" id="error-mensaje" aria-live="polite"></span>
          </div>

          <button type="submit" class="btn-submit" id="btn-submit">
            <span id="btn-text">Enviar consulta</span>
            <span id="btn-loading" hidden aria-hidden="true">
              <svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              </svg>
              Enviando...
            </span>
          </button>

          <p class="form-privacy">
            Tu información es confidencial y no será compartida con terceros.
          </p>
        </form>
      </div>
    </div>
  </section>

  <VideoConsultaBanner />
</Page>

<script>
  import { z } from 'zod';

  // Schema isomórfico (mismo que en contactSchema.ts)
  const motivoOptions = [
    'Disfunción Eréctil',
    'Eyaculación Precoz',
    'Falta de Deseo',
    'Terapia Hormonal',
    'Urología',
    'Otra consulta',
  ] as const;

  const contactSchema = z.object({
    nombre:   z.string().min(2, 'El nombre debe tener al menos 2 caracteres').max(100),
    telefono: z.string().min(6, 'Ingresá un teléfono válido').max(30)
               .regex(/^[\d\s\+\-\(\)]+$/, 'Solo números y símbolos (+, -, paréntesis)'),
    email:    z.string().email('Ingresá un email válido').max(254),
    motivo:   z.enum(motivoOptions, { errorMap: () => ({ message: 'Seleccioná un motivo' }) }),
    mensaje:  z.string().min(10, 'El mensaje debe tener al menos 10 caracteres').max(2000),
  });

  const form      = document.getElementById('contact-form') as HTMLFormElement;
  const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;
  const btnText   = document.getElementById('btn-text') as HTMLSpanElement;
  const btnLoad   = document.getElementById('btn-loading') as HTMLSpanElement;
  const success   = document.getElementById('form-success') as HTMLDivElement;
  const errorBox  = document.getElementById('form-error') as HTMLDivElement;
  const errorMsg  = document.getElementById('form-error-msg') as HTMLParagraphElement;

  // Limpiar error de un campo
  function clearError(name: string) {
    const el = document.getElementById(`error-${name}`);
    const input = form.elements.namedItem(name) as HTMLElement;
    if (el) el.textContent = '';
    input?.removeAttribute('aria-invalid');
  }

  // Mostrar error de un campo
  function showError(name: string, message: string) {
    const el = document.getElementById(`error-${name}`);
    const input = form.elements.namedItem(name) as HTMLElement;
    if (el) el.textContent = message;
    input?.setAttribute('aria-invalid', 'true');
  }

  // Limpiar todos los errores
  function clearAllErrors() {
    ['nombre', 'telefono', 'email', 'motivo', 'mensaje'].forEach(clearError);
  }

  // Validar en tiempo real al salir de un campo (blur)
  form.querySelectorAll('input, select, textarea').forEach(el => {
    el.addEventListener('blur', () => {
      const name = (el as HTMLInputElement).name;
      const value = (el as HTMLInputElement).value;
      const fieldSchema = contactSchema.shape[name as keyof typeof contactSchema.shape];
      if (!fieldSchema) return;
      const result = fieldSchema.safeParse(value);
      if (!result.success) {
        showError(name, result.error.issues[0]?.message ?? 'Campo inválido');
      } else {
        clearError(name);
      }
    });

    el.addEventListener('input', () => {
      clearError((el as HTMLInputElement).name);
    });
  });

  // Submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearAllErrors();

    const data = Object.fromEntries(new FormData(form));
    const result = contactSchema.safeParse(data);

    // Validación client-side
    if (!result.success) {
      result.error.issues.forEach(issue => {
        const field = issue.path[0] as string;
        showError(field, issue.message);
      });
      // Focus en el primer campo con error
      const firstError = result.error.issues[0]?.path[0] as string;
      (form.elements.namedItem(firstError) as HTMLElement)?.focus();
      return;
    }

    // Loading state
    btnSubmit.disabled = true;
    btnText.hidden = true;
    btnLoad.hidden = false;
    errorBox.hidden = true;

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(result.data),
      });

      const json = await res.json() as { message?: string };

      if (res.ok) {
        form.hidden = true;
        success.hidden = false;
        success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        errorMsg.textContent = json.message ?? 'Error al enviar. Intentá de nuevo.';
        errorBox.hidden = false;
        errorBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    } catch {
      errorMsg.textContent = 'Error de conexión. Verificá tu internet e intentá de nuevo.';
      errorBox.hidden = false;
    } finally {
      btnSubmit.disabled = false;
      btnText.hidden = false;
      btnLoad.hidden = true;
    }
  });
</script>

<style>
  /* Hero */
  .page-hero {
    position: relative;
    background:
      radial-gradient(1200px 280px at 12% -18%, rgba(201, 168, 76, 0.2), transparent 52%),
      radial-gradient(900px 260px at 90% 0%, rgba(63, 135, 214, 0.14), transparent 48%),
      linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-dark) 100%);
    padding: 3.5rem 0 3rem;
    color: var(--color-white);
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--color-white);
    margin: 0.75rem 0 1rem;
  }

  .page-hero__lead {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.88);
    max-width: 540px;
    line-height: 1.65;
  }

  .breadcrumb ol {
    display: flex;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: 0.5rem;
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: 0.5rem;
    opacity: 0.65;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.86);
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--color-gold-light);
  }

  /* Layout */
  .contact-section {
    position: relative;
    padding: 4rem 0 5rem;
    background:
      radial-gradient(900px 500px at 12% 14%, rgba(63, 135, 214, 0.08), transparent 62%),
      radial-gradient(760px 420px at 88% 80%, rgba(201, 168, 76, 0.08), transparent 60%),
      linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-2) 100%);
    overflow: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  /* Side info */
  .contact-info h2 {
    font-size: 1.125rem;
    color: var(--color-gold-light);
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .info-card {
    display: flex;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
    padding: 1.05rem;
    background: linear-gradient(148deg, rgba(19, 29, 55, 0.96), rgba(12, 20, 40, 0.94));
    border: 1px solid rgba(122, 155, 181, 0.22);
    border-radius: var(--radius-md);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.26);
  }

  .info-card__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(201, 168, 76, 0.14);
    border: 1px solid rgba(201, 168, 76, 0.36);
    border-radius: var(--radius-sm);
    color: var(--color-gold-light);
  }

  .info-card__icon--wa {
    background-color: rgba(57, 198, 118, 0.16);
    border-color: rgba(57, 198, 118, 0.36);
    color: #58d389;
  }

  .info-card h3 {
    font-size: 0.93rem;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .info-card p {
    font-size: 0.84rem;
    color: rgba(226, 232, 244, 0.86);
    line-height: 1.45;
  }

  .info-note {
    font-style: italic;
    color: rgba(155, 196, 234, 0.9);
  }

  .wa-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: #7bf1ad;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .contact-disclaimer {
    margin-top: 1.5rem;
    padding: 0.8rem 1rem;
    background-color: rgba(88, 60, 12, 0.36);
    border: 1px solid rgba(233, 183, 77, 0.45);
    border-left: 3px solid rgba(233, 183, 77, 0.78);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: 0.8rem;
    color: #f6de9e;
    line-height: 1.55;
  }

  /* Feedback states */
  .form-feedback {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 2.5rem 2rem;
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
    border: 1px solid rgba(122, 155, 181, 0.24);
  }

  .form-feedback h3 {
    font-size: 1.25rem;
  }

  .form-feedback p {
    font-size: 0.9375rem;
    color: rgba(226, 232, 244, 0.86);
  }

  .form-feedback--success {
    background-color: rgba(25, 84, 56, 0.28);
    color: #8ae1b1;
  }

  .form-feedback--success svg {
    color: #69d89d;
  }

  .form-feedback--success h3 {
    color: #8ae1b1;
  }

  .form-feedback--error {
    background-color: rgba(134, 29, 45, 0.25);
    color: #ffb8c1;
  }

  .form-feedback--error svg {
    color: #ff7f8f;
  }

  .form-feedback--error h3 {
    color: #ffb8c1;
  }

  /* Form */
  .contact-form-wrapper {
    background: linear-gradient(160deg, rgba(20, 30, 56, 0.94), rgba(11, 18, 36, 0.96));
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.32);
    border: 1px solid rgba(122, 155, 181, 0.24);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 1.25rem;
  }

  label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .field-hint {
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(155, 196, 234, 0.86);
  }

  input,
  select,
  textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    background-color: rgba(7, 12, 26, 0.92);
    border: 1.5px solid rgba(122, 155, 181, 0.38);
    border-radius: var(--radius-md);
    transition: border-color 0.15s, box-shadow 0.15s, background-color 0.15s;
    outline: none;
  }

  input::placeholder,
  textarea::placeholder {
    color: rgba(155, 196, 234, 0.72);
  }

  select option {
    background-color: #0c1830;
    color: var(--color-text);
  }

  input:hover,
  select:hover,
  textarea:hover {
    border-color: rgba(201, 168, 76, 0.5);
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--color-gold-light);
    box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.22);
    background-color: rgba(9, 15, 30, 0.96);
  }

  input[aria-invalid='true'],
  select[aria-invalid='true'],
  textarea[aria-invalid='true'] {
    border-color: #ff7f8f;
    box-shadow: 0 0 0 3px rgba(255, 127, 143, 0.2);
  }

  textarea {
    resize: vertical;
    min-height: 130px;
  }

  .field-error {
    font-size: 0.8125rem;
    color: #ff9aa6;
    min-height: 1.1em;
  }

  .btn-submit {
    width: 100%;
    padding: 0.95rem 2rem;
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-gold));
    color: #1d2340;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    border-radius: var(--radius-md);
    cursor: pointer;
    border: 1px solid rgba(201, 168, 76, 0.78);
    transition: transform 0.15s, box-shadow 0.2s, filter 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    box-shadow: 0 10px 26px rgba(201, 168, 76, 0.26);
  }

  .btn-submit:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(201, 168, 76, 0.34);
    filter: brightness(1.03);
  }

  .btn-submit:disabled {
    opacity: 0.72;
    cursor: not-allowed;
  }

  .spinner {
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .form-privacy {
    font-size: 0.8rem;
    color: rgba(226, 232, 244, 0.78);
    text-align: center;
    line-height: 1.5;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .contact-info {
      order: 2;
    }

    .contact-form-wrapper {
      order: 1;
    }
  }

  @media (max-width: 560px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form-wrapper {
      padding: 1.5rem;
    }
  }
</style>

