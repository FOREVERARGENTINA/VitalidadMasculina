---
import { getCollection, render } from 'astro:content';
import Post from '../../layouts/Post.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(post => !post.id.startsWith('_'));
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Post
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  category={post.data.category ?? ''}
  image={post.data.image}
  author={post.data.author}
>
  <Content />
</Post>

<style is:global>
  /* Estilos tipográficos para el contenido renderizado desde Markdown */

  .post-content h2 {
    font-size: 1.5rem;
    color: var(--color-navy);
    margin: 2rem 0 0.875rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-navy-light);
  }

  .post-content h3 {
    font-size: 1.15rem;
    color: var(--color-navy);
    margin: 1.5rem 0 0.5rem;
  }

  .post-content p {
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: 1rem;
    font-size: 1.0625rem;
  }

  .post-content ul,
  .post-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .post-content li {
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: 0.375rem;
    font-size: 1rem;
  }

  .post-content strong {
    color: var(--color-navy);
    font-weight: 600;
  }

  .post-content a {
    color: var(--color-gold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content a:hover {
    color: var(--color-navy);
  }

  .post-content blockquote {
    border-left: 3px solid var(--color-gold);
    padding: 0.875rem 1.25rem;
    margin: 1.5rem 0;
    background-color: var(--color-navy-light);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .post-content blockquote p {
    color: var(--color-navy);
    font-style: italic;
    margin: 0;
  }

  .post-content img {
    border-radius: var(--radius-md);
    margin: 1.5rem 0;
    box-shadow: var(--shadow-sm);
  }

  /* Layout del Post */
  .post-header {
    max-width: 780px;
    margin: 0 auto 2.5rem;
    padding: 3rem 1.5rem 0;
  }

  .post-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }

  .post-header h1 {
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    color: var(--color-navy);
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .post-meta {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .post-header img {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-top: 1.5rem;
  }

  .post-content {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    max-width: 780px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem 0;
  }

  .breadcrumb ol {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .breadcrumb li + li::before { content: '/'; margin-right: 0.5rem; opacity: 0.5; }

  .breadcrumb a {
    color: var(--color-navy);
    transition: color 0.15s;
  }

  .breadcrumb a:hover { color: var(--color-gold); }

  /* CTA al final del artículo */
  .post-cta {
    max-width: 780px;
    margin: 3rem auto 4rem;
    padding: 2.5rem 1.5rem;
    background-color: var(--color-navy-light);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .post-cta p {
    font-size: 1.125rem;
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-weight: 700;
    margin-bottom: 1rem !important;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.8125rem 2rem;
    background-color: var(--color-gold);
    color: var(--color-white);
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: background-color 0.2s, transform 0.15s;
  }

  .btn-primary:hover {
    background-color: var(--color-navy);
    transform: translateY(-2px);
  }
</style>
