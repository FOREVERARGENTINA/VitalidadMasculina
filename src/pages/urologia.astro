---
import Page from '../layouts/Page.astro';
import VideoConsultaBanner from '../components/sections/VideoConsultaBanner.astro';
---

<Page
  title="Urología Masculina"
  description="Consultas de urología masculina con el Dr. Leandro Mateu en Zona Palermo, CABA. Atención también por videollamada."
>
  <section class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <ol>
          <li><a href="/">Inicio</a></li>
          <li aria-current="page">Urología</li>
        </ol>
      </nav>
      <h1>Urología Masculina</h1>
    </div>
  </section>

  <article class="page-content">
    <div class="container container--narrow">

      <!-- TODO: Contenido a desarrollar con el cliente -->
      <section class="content-section reveal">
        <p class="placeholder-notice">
          Esta sección está en desarrollo. Próximamente encontrarás información completa
          sobre los servicios de urología masculina disponibles en el consultorio.
        </p>
        <p>
          Para consultas sobre urología, podés comunicarte directamente a través del
          formulario de contacto o por WhatsApp.
        </p>
      </section>

      <div class="page-cta">
        <h2>¿Tenés una consulta de urología?</h2>
        <p>Contactanos y te respondemos a la brevedad.</p>
        <a href="/contacto" class="btn-primary">Solicitá tu consulta</a>
      </div>

    </div>
  </article>

  <VideoConsultaBanner />
</Page>

<style>
  .placeholder-notice {
    background-color: var(--color-bg-2);
    border-left: 3px solid var(--color-gold);
    padding: 1rem 1.25rem;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-style: italic;
    color: var(--color-text-muted);
  }
</style>
