---
import Page from '../layouts/Page.astro';
import VideoConsultaBanner from '../components/sections/VideoConsultaBanner.astro';
import { MEDICO_NOMBRE, CONSULTORIO_ZONA, SITE_URL } from '../utils/constants';

const schemaPerson = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: MEDICO_NOMBRE,
  jobTitle: 'Especialista en Salud Masculina',
  // TODO: completar con especialidad, matrícula y foto reales cuando el cliente los provea
  worksFor: {
    '@type': 'MedicalBusiness',
    name: 'Vitalidad Masculina',
    url: SITE_URL,
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: CONSULTORIO_ZONA,
    addressCountry: 'AR',
  },
};

const fotoPlaceholder = '/images/consultorio.webp';
---

<Page
  title={`Sobre mí · ${MEDICO_NOMBRE}`}
  description={`Conocé al ${MEDICO_NOMBRE}, especialista en salud masculina en ${CONSULTORIO_ZONA}. Atención presencial y por videollamada.`}
>
  <slot name="head" slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaPerson)} />
  </slot>

  <section class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <ol>
          <li><a href="/">Inicio</a></li>
          <li aria-current="page">Sobre mí</li>
        </ol>
      </nav>
      <h1>Sobre mí</h1>
    </div>
  </section>

  <article class="page-content">
    <div class="container">
      <div class="perfil">

        <!-- Foto -->
        <div class="perfil__foto">
          <img
            src={fotoPlaceholder}
            alt="Consultorio de medicina masculina — diplomas y biblioteca médica"
            width="800"
            height="600"
            loading="eager"
            class="foto-img"
          />
        </div>

        <!-- Contenido -->
        <div class="perfil__contenido">

          <p class="perfil__nombre-label">Medicina masculina · {CONSULTORIO_ZONA}</p>
          <h2 class="perfil__nombre">{MEDICO_NOMBRE}</h2>

          <div class="perfil__especialidad">
            <span class="tag">Especialista en Salud Masculina</span>
          </div>

          <p class="perfil__bio">
            Una práctica médica privada dedicada íntegramente a la salud del hombre.
            El enfoque es integral: se trabaja sobre el origen del problema, no solo
            sobre el síntoma, con diagnóstico de precisión y seguimiento personalizado.
          </p>
          <p class="perfil__bio">
            Cada consulta se desarrolla en un entorno de absoluta reserva, sin listas
            de espera, con el tiempo necesario para escuchar y planificar el tratamiento
            más adecuado para cada paciente.
          </p>

          <!-- Modalidades de atención -->
          <div class="modalidades">
            <h3>Modalidades de atención</h3>
            <ul class="modalidades__list" role="list">
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                <span>Presencial — Zona {CONSULTORIO_ZONA}</span>
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
                <span>Videollamada — disponible para toda Argentina</span>
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <span>Solo particular — atención personalizada sin demoras</span>
              </li>
            </ul>
          </div>

          <a href="/contacto" class="btn-primary">Solicitá tu consulta</a>
        </div>
      </div>
    </div>
  </article>

  <VideoConsultaBanner />
</Page>

<style>
  .page-content { padding: 4rem 0 5rem; }

  /* Layout perfil */
  .perfil {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .perfil__foto { position: relative; }

  .foto-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .perfil__badge {
    position: absolute;
    bottom: -1rem;
    right: -1rem;
    background-color: var(--color-gold);
    color: var(--color-bg-hero);
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    text-align: center;
    min-width: 130px;
  }

  .badge-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.85;
  }

  .badge-value {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
  }

  .perfil__nombre-label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: 0.375rem;
  }

  .perfil__nombre {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .perfil__especialidad { margin-bottom: 1.5rem; }

  .tag {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    background-color: var(--color-bg-2);
    color: var(--color-text-muted);
    border: 1px solid rgba(226, 232, 244, 0.12);
    border-radius: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    min-width: 180px;
    min-height: 1.5rem;
  }

  .perfil__bio {
    color: var(--color-text-muted);
    line-height: 1.78;
    margin-bottom: 1rem;
    font-size: 1.0625rem;
  }

  .modalidades { margin: 1.75rem 0 2rem; }

  .modalidades h3 {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 0.875rem;
    font-family: var(--font-body);
    font-weight: 600;
  }

  .modalidades__list {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .modalidades__list li {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .modalidades__list svg { color: var(--color-electric); flex-shrink: 0; }

  /* Responsive */
  @media (max-width: 900px) {
    .perfil { grid-template-columns: 1fr; gap: 3rem; }
    .perfil__foto { max-width: 360px; margin: 0 auto; }
    .perfil__badge { right: 0; }
  }
</style>
