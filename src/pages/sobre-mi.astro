---
import Page from '../layouts/Page.astro';
import VideoConsultaBanner from '../components/sections/VideoConsultaBanner.astro';
import { MEDICO_NOMBRE, CONSULTORIO_ZONA, SITE_URL } from '../utils/constants';

const schemaPerson = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: MEDICO_NOMBRE,
  jobTitle: 'Especialista en Salud Masculina',
  // TODO: completar con especialidad, matrícula y foto reales cuando el cliente los provea
  worksFor: {
    '@type': 'MedicalBusiness',
    name: 'Vitalidad Masculina',
    url: SITE_URL,
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: CONSULTORIO_ZONA,
    addressCountry: 'AR',
  },
};

// TODO: reemplazar por foto profesional real cuando el cliente la provea
// Imagen de Unsplash — médico masculino, entorno profesional
const fotoPlaceholder = 'https://images.unsplash.com/photo-1622253692010-333f2da6031d?w=600&q=80';
---

<Page
  title={`Sobre mí · ${MEDICO_NOMBRE}`}
  description={`Conocé al ${MEDICO_NOMBRE}, especialista en salud masculina en ${CONSULTORIO_ZONA}. Atención presencial y por videollamada.`}
>
  <slot name="head" slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaPerson)} />
  </slot>

  <section class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <ol>
          <li><a href="/">Inicio</a></li>
          <li aria-current="page">Sobre mí</li>
        </ol>
      </nav>
      <h1>Sobre mí</h1>
    </div>
  </section>

  <article class="page-content">
    <div class="container">
      <div class="perfil">

        <!-- Foto -->
        <div class="perfil__foto">
          <!-- TODO: reemplazar por foto profesional real cuando el cliente la provea -->
          <img
            src={fotoPlaceholder}
            alt={`Retrato del ${MEDICO_NOMBRE}`}
            width="480"
            height="560"
            loading="eager"
            class="foto-img"
          />
          <div class="perfil__badge">
            <!-- TODO: completar con matrícula cuando el cliente la provea -->
            <span class="badge-label">Matrícula</span>
            <span class="badge-value">Pendiente</span>
          </div>
        </div>

        <!-- Contenido -->
        <div class="perfil__contenido">

          <p class="perfil__nombre-label">Especialista en Salud Masculina</p>
          <h2 class="perfil__nombre">{MEDICO_NOMBRE}</h2>

          <!-- TODO: completar con especialidad y formación cuando el cliente las provea -->
          <div class="perfil__especialidad">
            <span class="tag"><!-- TODO: especialidad / título --></span>
          </div>

          <p class="perfil__bio">
            <!-- TODO: reemplazar con la biografía y trayectoria profesional que provea el cliente -->
            El {MEDICO_NOMBRE} es especialista en salud masculina con foco en el diagnóstico y
            tratamiento integral de problemáticas que impactan en la calidad de vida del hombre.
          </p>
          <p class="perfil__bio">
            Su enfoque combina el rigor clínico con una atención cercana y personalizada,
            entendiendo que cada paciente tiene una historia y un contexto únicos.
          </p>

          <!-- Modalidades de atención -->
          <div class="modalidades">
            <h3>Modalidades de atención</h3>
            <ul class="modalidades__list" role="list">
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                <span>Presencial — Zona {CONSULTORIO_ZONA}</span>
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
                <span>Videollamada — disponible para toda Argentina</span>
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <span>Solo particular — atención personalizada sin demoras</span>
              </li>
            </ul>
          </div>

          <a href="/contacto" class="btn-primary">Solicitá tu consulta</a>
        </div>
      </div>
    </div>
  </article>

  <VideoConsultaBanner />
</Page>

<style>
  .page-hero { background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-dark) 100%); padding: 3.5rem 0 3rem; color: var(--color-white); }
  .page-hero h1 { font-size: clamp(2rem, 4vw, 2.75rem); color: var(--color-white); margin: 0.75rem 0 0; }
  .breadcrumb ol { display: flex; gap: 0.5rem; font-size: 0.8125rem; color: rgba(255,255,255,0.55); margin-bottom: 0.5rem; }
  .breadcrumb li + li::before { content: '/'; margin-right: 0.5rem; opacity: 0.5; }
  .breadcrumb a { color: rgba(255,255,255,0.7); transition: color 0.15s; }
  .breadcrumb a:hover { color: var(--color-gold); }

  .page-content { padding: 4rem 0 5rem; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

  /* Layout perfil */
  .perfil {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Foto */
  .perfil__foto { position: relative; }

  .foto-img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .perfil__badge {
    position: absolute;
    bottom: -1rem;
    right: -1rem;
    background-color: var(--color-gold);
    color: var(--color-white);
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    text-align: center;
    min-width: 130px;
  }

  .badge-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.85;
  }

  .badge-value {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
  }

  /* Contenido */
  .perfil__nombre-label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: 0.375rem;
  }

  .perfil__nombre {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-navy);
    margin-bottom: 0.75rem;
  }

  .perfil__especialidad {
    margin-bottom: 1.5rem;
  }

  .tag {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    background-color: var(--color-navy-light);
    color: var(--color-navy);
    border-radius: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    min-width: 180px;
    min-height: 1.5rem;
  }

  .perfil__bio {
    color: var(--color-text);
    line-height: 1.75;
    margin-bottom: 1rem;
    font-size: 1.0625rem;
  }

  /* Modalidades */
  .modalidades { margin: 1.75rem 0 2rem; }

  .modalidades h3 {
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 0.875rem;
    font-family: var(--font-body);
    font-weight: 600;
  }

  .modalidades__list {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .modalidades__list li {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .modalidades__list svg { color: var(--color-navy); flex-shrink: 0; }

  .btn-primary {
    display: inline-block;
    padding: 0.8125rem 2rem;
    background-color: var(--color-gold);
    color: var(--color-white);
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: background-color 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background-color: var(--color-navy); transform: translateY(-2px); }

  /* Responsive */
  @media (max-width: 900px) {
    .perfil { grid-template-columns: 1fr; gap: 3rem; }
    .perfil__foto { max-width: 360px; margin: 0 auto; }
    .perfil__badge { right: 0; }
  }
</style>
