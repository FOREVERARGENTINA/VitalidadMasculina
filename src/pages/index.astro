---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import ServiceCard from '../components/sections/ServiceCard.astro';
import BlogCard from '../components/sections/BlogCard.astro';
import VideoConsultaBanner from '../components/sections/VideoConsultaBanner.astro';
import { SITE_NAME, MEDICO_NOMBRE, CONSULTORIO_ZONA } from '../utils/constants';

// Últimas 3 entradas del blog (si hay)
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const services = [
  {
    title: 'Disfunción Eréctil',
    description: 'Evaluacion integral y plan terapeutico personalizado segun cada caso clinico.',
    href: '/disfuncion-erectil',
    icon: 'heart' as const,
  },
  {
    title: 'Eyaculación Precoz',
    description: 'Abordaje medico y conductual con protocolos basados en evidencia.',
    href: '/eyaculacion-precoz',
    icon: 'clock' as const,
  },
  {
    title: 'Falta de Deseo',
    description: 'Estudio hormonal, emocional y metabolico de la disminucion del deseo.',
    href: '/falta-de-deseo',
    icon: 'flame' as const,
  },
  {
    title: 'Terapia Hormonal',
    description: 'Reposicion con pellets de testosterona de liberacion prolongada en consultorio.',
    href: '/terapia-hormonal',
    icon: 'activity' as const,
  },
  {
    title: 'Urología Masculina',
    description: 'Consulta urologica integral para prevencion, diagnostico y seguimiento.',
    href: '/urologia',
    icon: 'shield' as const,
  },
];
---

<Base
  title={`${SITE_NAME} · Especialista en Salud Masculina`}
  description={`El ${MEDICO_NOMBRE} ofrece consultas especializadas en salud masculina en ${CONSULTORIO_ZONA} y por videollamada para toda Argentina.`}
>
  <Header />

  <main id="main-content">

    <!-- ── Hero ───────────────────────────────────────────────── -->
    <Hero />

    <!-- ── Stats ──────────────────────────────────────────────── -->
    <section class="section-stats" aria-label="Indicadores del consultorio">
      <div class="stats-container">
        <div class="stat-item reveal">
          <span class="stat-number">10+</span>
          <span class="stat-label">Años en ejercicio</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item reveal">
          <span class="stat-number">500+</span>
          <span class="stat-label">Pacientes atendidos</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item reveal">
          <span class="stat-number">100%</span>
          <span class="stat-label">Privado y confidencial</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item reveal">
          <span class="stat-number">∞</span>
          <span class="stat-label">Disponible por video</span>
        </div>
      </div>
    </section>

    <!-- ── Servicios ──────────────────────────────────────────── -->
    <section id="servicios" class="section section--light" aria-labelledby="servicios-heading">
      <div class="container">
        <header class="section-header">
          <p class="section-eyebrow">Especialidades</p>
          <h2 id="servicios-heading">Áreas de atención</h2>
          <p class="section-lead">
            Abordaje integral de la salud masculina con diagnóstico personalizado
            y tratamientos basados en evidencia científica.
          </p>
          <ul class="service-trust" role="list" aria-label="Diferenciales de atencion">
            <li>Atencion presencial y videoconsulta</li>
            <li>Enfoque medico basado en evidencia</li>
            <li>Seguimiento personalizado del tratamiento</li>
          </ul>
        </header>

        <div class="services-grid">
          {services.map((s, i) => (
            <div class={`service-slot service-slot--${i + 1}`}>
              <ServiceCard
                title={s.title}
                description={s.description}
                href={s.href}
                icon={s.icon}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Sobre el Dr. ───────────────────────────────────────── -->
    <section class="section section--navy" aria-labelledby="doctor-heading">
      <div class="container doctor-section">
        <div class="doctor-img-wrapper reveal">
          <!-- TODO: reemplazar por foto profesional real cuando el cliente la provea -->
          <img
            src="https://images.unsplash.com/photo-1622253692010-333f2da6031d?w=500&q=80"
            alt={`Retrato del ${MEDICO_NOMBRE}`}
            width="500"
            height="600"
            loading="lazy"
            class="doctor-img"
          />
        </div>

        <div class="doctor-content reveal">
          <p class="section-eyebrow section-eyebrow--gold">Sobre el especialista</p>
          <h2 id="doctor-heading">{MEDICO_NOMBRE}</h2>
          <p class="doctor-specialty">
            <!-- TODO: completar con especialidad cuando el cliente la provea -->
            Especialista en Salud Masculina · {CONSULTORIO_ZONA}
          </p>
          <p class="doctor-bio">
            Atención personalizada con un enfoque que integra la salud física,
            hormonal y emocional del paciente. Consultas presenciales en Zona Palermo
            y por videollamada para toda Argentina.
          </p>

          <ul class="doctor-features" role="list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Diagnóstico integral y personalizado
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Atención presencial y por videollamada
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Solo particular — sin tiempos de espera
            </li>
          </ul>

          <a href="/sobre-mi" class="btn-outline-white">
            Conocer más
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Videoconsulta ──────────────────────────────────────── -->
    <VideoConsultaBanner />

    <!-- ── Blog (solo si hay artículos) ──────────────────────── -->
    {posts.length > 0 && (
      <section class="section section--light" aria-labelledby="blog-heading">
        <div class="container">
          <header class="section-header">
            <p class="section-eyebrow">Blog</p>
            <h2 id="blog-heading">Últimas notas</h2>
            <p class="section-lead">
              Información sobre salud masculina escrita por el especialista.
            </p>
          </header>

          <div class="blog-grid">
            {posts.map(post => (
              <BlogCard
                title={post.data.title}
                excerpt={post.data.description}
                slug={post.id.replace(/\.md$/, '')}
                image={post.data.image}
                category={post.data.category}
                pubDate={post.data.pubDate}
              />
            ))}
          </div>

          <div class="section-cta-center">
            <a href="/blog" class="btn-outline-navy">Ver todos los artículos</a>
          </div>
        </div>
      </section>
    )}

    <!-- ── CTA final ──────────────────────────────────────────── -->
    <section class="section cta-final" aria-labelledby="cta-heading">
      <div class="container cta-final__inner">
        <h2 id="cta-heading">¿Listo para dar el primer paso?</h2>
        <p>
          Turnos disponibles de forma presencial en Zona Palermo, CABA<br />
          y por videollamada desde cualquier punto del país.
        </p>
        <a href="/contacto" class="btn-primary-lg">
          Solicitar consulta
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Base>

<style>
  /* ── Utilidades de sección ──────────────────────────────────── */
  .section {
    padding: 6.25rem 0;
  }

  .section--light {
    background: var(--color-bg-2);
  }

  .section--navy {
    position: relative;
    isolation: isolate;
    background:
      radial-gradient(900px 400px at 10% -10%, rgba(74, 158, 255, 0.08), transparent 55%),
      radial-gradient(700px 320px at 88% 108%, rgba(201, 168, 76, 0.10), transparent 58%),
      linear-gradient(135deg, #060c1c 0%, #0a1628 60%, #0d1d35 100%);
  }

  .section--navy::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      repeating-linear-gradient(
        -45deg,
        rgba(74, 158, 255, 0.025) 0px,
        rgba(74, 158, 255, 0.025) 1px,
        transparent 1px,
        transparent 18px
      );
    opacity: 0.5;
    pointer-events: none;
  }

  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.75rem;
  }

  /* ── Encabezados de sección ─────────────────────────────────── */
  .section-header {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 3.6rem;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-gold);
    margin-bottom: 0.7rem;
  }

  .section-eyebrow--gold {
    color: var(--color-gold);
  }

  .section-header h2 {
    font-size: clamp(2rem, 3.3vw, 2.8rem);
    margin-bottom: 1rem;
    letter-spacing: 0.01em;
  }

  .section-lead {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.78;
    max-width: 62ch;
    margin: 0 auto;
  }

  .service-trust {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.72rem;
    margin-top: 1.45rem;
  }

  .service-trust li {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: rgba(74, 158, 255, 0.06);
    border: 1px solid rgba(74, 158, 255, 0.18);
    border-radius: 999px;
    padding: 0.48rem 0.82rem;
  }

  /* ── Grid de servicios ──────────────────────────────────────── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .service-slot--1 { grid-column: 1 / span 4; }
  .service-slot--2 { grid-column: 5 / span 4; }
  .service-slot--3 { grid-column: 9 / span 4; }
  .service-slot--4 { grid-column: 3 / span 4; }
  .service-slot--5 { grid-column: 7 / span 4; }

  /* ── Sección doctor ──────────────────────────────────────────── */
  .doctor-section {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 5rem;
    align-items: center;
  }

  .doctor-img-wrapper {
    position: relative;
  }

  .doctor-img-wrapper::after {
    content: '';
    position: absolute;
    inset: 14px -14px -14px 14px;
    border: 1px solid rgba(201, 168, 76, 0.35);
    border-radius: var(--radius-lg);
    z-index: -1;
  }

  .doctor-img {
    width: 100%;
    aspect-ratio: 5 / 6;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.35);
  }

  .doctor-content h2 {
    font-size: clamp(2rem, 3vw, 2.75rem);
    color: var(--color-white);
    margin-bottom: 0.6rem;
    letter-spacing: 0.01em;
  }

  .doctor-specialty {
    font-size: 0.79rem;
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: 1.4rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .doctor-bio {
    font-size: 1.08rem;
    color: rgba(255, 255, 255, 0.84);
    line-height: 1.8;
    margin-bottom: 1.65rem;
    max-width: 56ch;
  }

  .doctor-features {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 2rem;
  }

  .doctor-features li {
    display: flex;
    align-items: center;
    gap: 0.56rem;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .doctor-features svg {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.86rem 1.7rem;
    border: 2px solid rgba(255, 255, 255, 0.5);
    color: var(--color-white);
    font-weight: 700;
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 999px;
    transition: border-color 0.2s, background-color 0.2s, transform 0.15s;
  }

  .btn-outline-white:hover {
    border-color: var(--color-white);
    background-color: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
  }

  /* ── Blog grid ───────────────────────────────────────────────── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.1rem;
    margin-bottom: 2.8rem;
  }

  .section-cta-center {
    text-align: center;
  }

  .btn-outline-navy {
    display: inline-block;
    padding: 0.84rem 1.8rem;
    border: 1px solid rgba(74, 158, 255, 0.35);
    color: var(--color-electric);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
    transition: background-color 0.2s, border-color 0.2s, transform 0.15s;
  }

  .btn-outline-navy:hover {
    background-color: rgba(74, 158, 255, 0.08);
    border-color: rgba(74, 158, 255, 0.6);
    transform: translateY(-2px);
  }

  /* ── CTA final ───────────────────────────────────────────────── */
  .cta-final {
    background:
      radial-gradient(ellipse at 15% 50%, rgba(74, 158, 255, 0.12), transparent 55%),
      radial-gradient(ellipse at 85% 40%, rgba(201, 168, 76, 0.10), transparent 55%),
      #060c1c;
  }

  .cta-final__inner {
    text-align: center;
    max-width: 640px;
  }

  .cta-final h2 {
    font-size: clamp(2rem, 3vw, 2.7rem);
    color: var(--color-text);
    margin-bottom: 1.1rem;
  }

  .cta-final p {
    font-size: 1.12rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 2.3rem;
  }

  .btn-primary-lg {
    display: inline-block;
    padding: 1.05rem 2.6rem;
    background-color: var(--color-gold);
    color: var(--color-bg-hero);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 999px;
    box-shadow: 0 8px 24px rgba(201, 168, 76, 0.3);
    transition: background-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .btn-primary-lg:hover {
    background-color: #dbb94f;
    transform: translateY(-2px);
    box-shadow: 0 0 32px rgba(201, 168, 76, 0.4), 0 10px 24px rgba(201, 168, 76, 0.2);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .service-trust {
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    .service-slot {
      grid-column: span 1 !important;
    }

    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 900px) {
    .doctor-section {
      grid-template-columns: 1fr;
      gap: 2.8rem;
    }
    .doctor-img-wrapper {
      max-width: 320px;
      margin: 0 auto;
    }
    .doctor-content {
      text-align: center;
    }
    .doctor-features {
      align-items: center;
    }
  }

  @media (max-width: 600px) {
    .section { padding: 3.5rem 0; }
    .service-trust { justify-content: flex-start; }
    .services-grid { grid-template-columns: 1fr !important; }
    .blog-grid { grid-template-columns: 1fr; }
  }

  /* ── Stats section ───────────────────────────────────────── */
  .section-stats {
    background: #060c1c;
    padding: 3.5rem 1.75rem;
    border-top: 1px solid rgba(74, 158, 255, 0.08);
    border-bottom: 1px solid rgba(74, 158, 255, 0.08);
  }

  .stats-container {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .stat-divider {
    width: 1px;
    height: 3.5rem;
    background: rgba(74, 158, 255, 0.18);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .stats-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem 1rem;
    }
    .stat-divider { display: none; }
  }
</style>

