---
// Hero principal del homepage
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-bg" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-line" aria-hidden="true"></div>
    <p class="hero-eyebrow">Práctica médica privada en salud masculina</p>

    <h1 id="hero-heading" class="hero-title">
      Medicina masculina<br />
      <span class="hero-title--accent">de precisión y máxima discreción</span>
    </h1>

    <p class="hero-subtitle">
      Diagnóstico integral, tratamiento personalizado y seguimiento cercano en un entorno reservado.
      Atención presencial en Palermo y videoconsulta para pacientes de toda Argentina.
    </p>

    <div class="hero-actions">
      <a href="/contacto" class="btn btn--primary">
        Coordinar consulta privada
      </a>
      <a href="#servicios" class="btn btn--outline">
        Explorar especialidades
      </a>
    </div>

    <div class="hero-trust">
      <span>Atención 1 a 1</span>
      <span class="trust-sep" aria-hidden="true">·</span>
      <span>Telemedicina premium</span>
      <span class="trust-sep" aria-hidden="true">·</span>
      <span>Confidencialidad absoluta</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 62svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: var(--color-bg-hero);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/hero.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(6, 12, 28, 0.92) 0%,
      rgba(6, 12, 28, 0.65) 50%,
      rgba(6, 12, 28, 0.08) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 1240px;
    margin: 0 auto;
    padding: 4rem 1.75rem;
    width: 100%;
  }

  /* ── Animaciones de entrada ────────────────────────────────── */
  @keyframes hero-line-grow {
    from { width: 0; opacity: 0; }
    to   { width: 80px; opacity: 1; }
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes cta-pulse {
    0%, 100% {
      box-shadow:
        0 8px 20px rgba(201, 168, 76, 0.28),
        0 0 0 0 rgba(201, 168, 76, 0);
    }
    50% {
      box-shadow:
        0 8px 28px rgba(201, 168, 76, 0.42),
        0 0 0 7px rgba(201, 168, 76, 0.07);
    }
  }

  /* Línea decorativa eléctrica */
  .hero-line {
    width: 80px;
    height: 2px;
    background: rgba(63, 135, 214, 0.72);
    margin-bottom: 1.5rem;
    box-shadow: 0 0 6px rgba(63, 135, 214, 0.22);
    animation: hero-line-grow 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.05s;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-gold-light);
    margin-bottom: 1.1rem;
    animation: hero-fade-up 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.22s;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.05;
    letter-spacing: 0.01em;
    margin-bottom: 1rem;
    max-width: 620px;
    animation: hero-fade-up 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.38s;
  }

  .hero-title--accent {
    color: var(--color-gold);
  }

  .hero-subtitle {
    font-size: clamp(0.94rem, 1.5vw, 1.05rem);
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.72;
    max-width: 520px;
    margin-bottom: 1.5rem;
    animation: hero-fade-up 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.58s;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 1.5rem;
    animation: hero-fade-up 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.76s;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.82rem 1.65rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: transform 0.15s ease, box-shadow 0.2s ease, background-color 0.2s;
    white-space: nowrap;
  }

  .btn--primary {
    background-color: var(--color-gold);
    color: var(--color-bg-hero);
    box-shadow: 0 8px 20px rgba(201, 168, 76, 0.28);
    animation: cta-pulse 3s ease-in-out infinite;
    animation-delay: 1.6s;
  }

  .btn--primary:hover {
    background-color: var(--color-gold-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(201, 168, 76, 0.38);
    animation-play-state: paused;
  }

  .btn--outline {
    background-color: transparent;
    color: var(--color-white);
    border: 1px solid rgba(255, 255, 255, 0.35);
  }

  .btn--outline:hover {
    border-color: rgba(255, 255, 255, 0.58);
    background-color: rgba(255, 255, 255, 0.06);
    transform: translateY(-2px);
  }

  /* Trust items inline */
  .hero-trust {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    animation: hero-fade-up 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.92s;
  }

  .trust-sep {
    color: var(--color-gold-light);
    opacity: 0.6;
  }

  @media (max-width: 900px) {
    .hero-title {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .hero {
      min-height: 54svh;
    }

    .hero-content {
      padding: 2.4rem 1rem 2.8rem;
    }

    .btn {
      width: 100%;
    }
  }
</style>
