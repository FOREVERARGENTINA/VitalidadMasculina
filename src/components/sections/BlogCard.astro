---
interface Props {
  title: string;
  excerpt: string;
  slug: string;
  image?: string;
  category?: string;
  pubDate?: Date;
}

const { title, excerpt, slug, image, category } = Astro.props;

// Imagen de fallback si el articulo no tiene imagen
const imgSrc = image || 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=800&q=75';
---

<article class="blog-card reveal">
  <a href={`/blog/${slug}`} class="blog-card__img-link" tabindex="-1" aria-hidden="true">
    <img
      src={imgSrc}
      alt={title}
      width="800"
      height="460"
      loading="lazy"
      class="blog-card__img"
    />
  </a>

  <div class="blog-card__body">
    {category && (
      <span class="blog-card__category">{category}</span>
    )}

    <h3 class="blog-card__title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>

    <p class="blog-card__excerpt">{excerpt}</p>

    <footer class="blog-card__footer">
      <a href={`/blog/${slug}`} class="blog-card__link" aria-label={`Leer más sobre ${title}`}>
        Leer más
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </footer>
  </div>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .blog-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .blog-card__img-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 800 / 460;
  }

  .blog-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .blog-card:hover .blog-card__img {
    transform: scale(1.04);
  }

  .blog-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.375rem 1.5rem 1.25rem;
  }

  .blog-card__category {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
  }

  .blog-card__title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    line-height: 1.3;
    color: var(--color-navy);
    margin-bottom: 0.625rem;
  }

  .blog-card__title a {
    color: inherit;
    transition: color 0.15s;
  }

  .blog-card__title a:hover {
    color: var(--color-gold);
  }

  .blog-card__excerpt {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.125rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    padding-top: 0.875rem;
    border-top: 1px solid var(--color-navy-light);
  }

  .blog-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-navy);
    transition: color 0.15s, gap 0.15s;
  }

  .blog-card__link:hover {
    color: var(--color-gold);
    gap: 0.5rem;
  }
</style>
