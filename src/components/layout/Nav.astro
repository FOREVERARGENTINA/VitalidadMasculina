---
const services = [
  { label: 'Disfunción Eréctil',  href: '/disfuncion-erectil' },
  { label: 'Eyaculación Precoz',  href: '/eyaculacion-precoz' },
  { label: 'Falta de Deseo',      href: '/falta-de-deseo'     },
  { label: 'Terapia Hormonal',    href: '/terapia-hormonal'   },
  { label: 'Urología',            href: '/urologia'           },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<nav aria-label="Navegación principal">
  <ul class="nav-list" role="list">
    <li>
      <a href="/" class:list={['nav-link', { 'nav-link--active': isActive('/') }]}>
        Inicio
      </a>
    </li>

    <!-- Dropdown Servicios -->
    <li class="nav-dropdown">
      <button
        class:list={['nav-link nav-link--dropdown', {
          'nav-link--active': services.some(s => isActive(s.href)),
        }]}
        aria-expanded="false"
        aria-haspopup="true"
      >
        Servicios
        <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true" fill="currentColor">
          <path d="M6 8L1 3h10L6 8z"/>
        </svg>
      </button>
      <ul class="dropdown-menu" role="list">
        {services.map(s => (
          <li>
            <a
              href={s.href}
              class:list={['dropdown-link', { 'dropdown-link--active': isActive(s.href) }]}
            >
              {s.label}
            </a>
          </li>
        ))}
      </ul>
    </li>

    <li>
      <a href="/blog" class:list={['nav-link', { 'nav-link--active': isActive('/blog') }]}>
        Blog
      </a>
    </li>
    <li>
      <a href="/sobre-mi" class:list={['nav-link', { 'nav-link--active': isActive('/sobre-mi') }]}>
        Sobre mí
      </a>
    </li>
  </ul>
</nav>

<style>
  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.9rem;
    font-size: 0.86rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    white-space: nowrap;
  }

  /* Underline via ::after */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0.2rem;
    left: 0.9rem;
    right: 0.9rem;
    height: 1.5px;
    background: var(--color-gold);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.22s ease;
    border-radius: 2px;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-text);
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after {
    transform: scaleX(0.7);
  }

  .nav-link--active {
    color: var(--color-gold);
    font-weight: 600;
  }

  .nav-link--active::after,
  .nav-link--active:hover::after,
  .nav-link--active:focus-visible::after {
    transform: scaleX(1);
  }

  /* Dropdown chevron */
  .nav-link--dropdown svg {
    transition: transform 0.2s;
  }
  .nav-link--dropdown[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .nav-dropdown {
    position: relative;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    min-width: 235px;
    background: color-mix(in srgb, var(--color-bg) 96%, transparent);
    border-radius: 12px;
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(226, 232, 244, 0.1);
    padding: 0.45rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.18s ease, visibility 0.18s ease, transform 0.18s ease;
    z-index: 50;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .nav-dropdown:hover .dropdown-menu,
  .nav-dropdown:focus-within .dropdown-menu,
  .nav-link--dropdown[aria-expanded="true"] ~ .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-link {
    display: block;
    padding: 0.52rem 0.82rem;
    font-size: 0.84rem;
    color: var(--color-text-muted);
    border-radius: 8px;
    transition: color 0.15s, background-color 0.15s;
    letter-spacing: 0.01em;
  }

  .dropdown-link:hover,
  .dropdown-link:focus-visible {
    color: var(--color-text);
    background-color: rgba(255, 255, 255, 0.07);
  }

  .dropdown-link--active {
    color: var(--color-gold);
    font-weight: 600;
    background: color-mix(in srgb, var(--color-gold) 10%, transparent);
  }
</style>

<script>
  // Toggle dropdown en mobile con teclado y click
  document.querySelectorAll<HTMLButtonElement>('.nav-link--dropdown').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });

  // Cerrar dropdown al hacer click fuera
  document.addEventListener('click', (e) => {
    document.querySelectorAll<HTMLButtonElement>('.nav-link--dropdown').forEach(btn => {
      const dropdown = btn.closest('.nav-dropdown');
      if (dropdown && !dropdown.contains(e.target as Node)) {
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>
