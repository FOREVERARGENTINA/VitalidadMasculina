---
import Nav from './Nav.astro';
import { SITE_NAME } from '../../utils/constants';
---

<header class="site-header" id="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="logo" aria-label={`${SITE_NAME} — Inicio`}>
      <!-- TODO: reemplazar con SVG del logo cuando esté disponible -->
      <img
        src="/images/logotipo.png"
        alt="Logo Vitalidad Masculina"
        class="logo-image"
        width="64"
        height="64"
        loading="eager"
        decoding="async"
      />
      <span class="logo-text">
        <span class="logo-title">Vitalidad Masculina</span>
        <span class="logo-subtitle">Dr. Leandro Mateu</span>
      </span>
    </a>

    <!-- Nav desktop -->
    <div class="header-nav">
      <Nav />
    </div>

    <!-- CTA desktop -->
    <a href="/contacto" class="btn-cta">
      Consulta privada
    </a>

    <!-- Botón hamburguesa mobile -->
    <button
      class="mobile-menu-btn"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>
  </div>

  <!-- Línea decorativa inferior -->
  <div class="header-bottom-line" aria-hidden="true"></div>

  <!-- Mobile overlay: full-screen, position fixed -->
  <div
    id="mobile-menu"
    class="mobile-overlay"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
    hidden
  >
    <div class="mobile-overlay__top">
      <span class="mobile-overlay__brand">Vitalidad Masculina</span>
      <button class="mobile-close" aria-label="Cerrar menú">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <nav class="mobile-nav" aria-label="Navegación mobile">
      <ul class="mobile-nav-list" role="list">
        <li class="mobile-nav-item">
          <a href="/" class="mobile-nav-link">Inicio</a>
        </li>
        <li class="mobile-nav-item mobile-nav-item--group">
          <span class="mobile-nav-group-label">Especialidades</span>
          <ul class="mobile-nav-sub" role="list">
            <li><a href="/disfuncion-erectil" class="mobile-nav-sublink">Disfunción Eréctil</a></li>
            <li><a href="/eyaculacion-precoz" class="mobile-nav-sublink">Eyaculación Precoz</a></li>
            <li><a href="/falta-de-deseo" class="mobile-nav-sublink">Falta de Deseo</a></li>
            <li><a href="/terapia-hormonal" class="mobile-nav-sublink">Terapia Hormonal</a></li>
            <li><a href="/urologia" class="mobile-nav-sublink">Urología</a></li>
          </ul>
        </li>
        <li class="mobile-nav-item">
          <a href="/blog" class="mobile-nav-link">Blog</a>
        </li>
        <li class="mobile-nav-item">
          <a href="/sobre-mi" class="mobile-nav-link">Sobre mí</a>
        </li>
      </ul>
    </nav>

    <div class="mobile-overlay__footer">
      <a href="/contacto" class="mobile-cta">
        Solicitar consulta
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
      <p class="mobile-overlay__tagline">Medicina masculina de precisión · Palermo, CABA</p>
    </div>
  </div>
</header>

<style>
  /* ── Header ──────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(6, 12, 28, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  /* Línea gold difuminada en el borde inferior */
  .header-bottom-line {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(201, 168, 76, 0.28) 30%,
      rgba(201, 168, 76, 0.5) 50%,
      rgba(201, 168, 76, 0.28) 70%,
      transparent 100%
    );
  }

  /* ── Inner floating bar ──────────────────────────────────────── */
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.55rem 1.5rem;
  }

  /* ── Logo ────────────────────────────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.72rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-image {
    width: 4rem;
    height: 4rem;
    object-fit: contain;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .logo:hover .logo-image {
    opacity: 0.88;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--color-text);
  }

  .logo-subtitle {
    font-size: 0.68rem;
    color: rgba(226, 232, 244, 0.55);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Nav desktop ─────────────────────────────────────────────── */
  .header-nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  /* ── CTA ─────────────────────────────────────────────────────── */
  .btn-cta {
    display: inline-block;
    padding: 0.58rem 1.25rem;
    background-color: var(--color-gold);
    color: var(--color-bg-hero);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(201, 168, 76, 0.28);
    transition: background-color 0.2s, transform 0.15s, box-shadow 0.2s;
    flex-shrink: 0;
  }

  .btn-cta:hover {
    background-color: var(--color-gold-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(201, 168, 76, 0.38);
  }

  /* ── Hamburguesa ─────────────────────────────────────────────── */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0.375rem;
    cursor: pointer;
    background: none;
    border: 1px solid rgba(226, 232, 244, 0.18);
    border-radius: var(--radius-sm);
    transition: border-color 0.2s;
  }

  .mobile-menu-btn:hover {
    border-color: rgba(201, 168, 76, 0.45);
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* ── Mobile overlay ──────────────────────────────────────────── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background:
      radial-gradient(ellipse at 20% 0%, rgba(63, 135, 214, 0.06), transparent 50%),
      radial-gradient(ellipse at 80% 100%, rgba(201, 168, 76, 0.06), transparent 50%),
      rgba(6, 12, 28, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    padding: 1.5rem 2rem 2rem;
    /* Estado cerrado */
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .mobile-overlay.is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mobile-overlay__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(226, 232, 244, 0.1);
  }

  .mobile-overlay__brand {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }

  .mobile-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid rgba(226, 232, 244, 0.2);
    border-radius: 50%;
    color: var(--color-text-muted);
    background: none;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .mobile-close:hover {
    border-color: rgba(201, 168, 76, 0.5);
    color: var(--color-gold);
  }

  /* Nav list */
  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .mobile-nav-item {
    border-bottom: 1px solid rgba(226, 232, 244, 0.07);
  }

  .mobile-nav-link {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 7vw, 2.5rem);
    font-weight: 700;
    color: rgba(226, 232, 244, 0.82);
    padding: 0.55rem 0;
    letter-spacing: 0.01em;
    transition: color 0.15s, transform 0.15s;
    display: block;
  }

  .mobile-nav-link:hover {
    color: var(--color-gold);
    transform: translateX(6px);
  }

  /* Specialties group */
  .mobile-nav-item--group {
    padding: 0.5rem 0 0.75rem;
  }

  .mobile-nav-group-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
  }

  .mobile-nav-sub {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.1rem 1rem;
  }

  .mobile-nav-sublink {
    display: block;
    font-size: 0.9rem;
    color: rgba(226, 232, 244, 0.6);
    padding: 0.3rem 0;
    transition: color 0.15s;
  }

  .mobile-nav-sublink:hover {
    color: var(--color-text);
  }

  /* Footer */
  .mobile-overlay__footer {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .mobile-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.95rem 2.2rem;
    background: var(--color-gold);
    color: var(--color-bg-hero);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    border-radius: 999px;
    box-shadow: 0 6px 20px rgba(201, 168, 76, 0.3);
    transition: background-color 0.2s, transform 0.15s;
  }

  .mobile-cta:hover {
    background-color: var(--color-gold-hover);
    transform: translateY(-2px);
  }

  .mobile-overlay__tagline {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(226, 232, 244, 0.25);
    text-align: center;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .header-nav,
    .btn-cta {
      display: none;
    }

    .logo-image {
      width: 3rem;
      height: 3rem;
    }

    .logo-title {
      font-size: 0.9rem;
    }

    .logo-subtitle {
      display: none;
    }

    .header-inner {
      padding: 0.5rem 1rem;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }
</style>

<script>
  const menuBtn = document.querySelector<HTMLButtonElement>('.mobile-menu-btn');
  const closeBtn = document.querySelector<HTMLButtonElement>('.mobile-close');
  const overlay = document.getElementById('mobile-menu') as HTMLElement | null;

  function openMenu() {
    if (!overlay) return;
    overlay.hidden = false;
    void overlay.offsetHeight; // fuerza reflow para activar la transición
    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    menuBtn?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    if (!overlay) return;
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
    menuBtn?.setAttribute('aria-expanded', 'false');
    overlay.addEventListener('transitionend', () => {
      overlay.hidden = true;
    }, { once: true });
  }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay?.hidden) closeMenu();
  });
</script>
