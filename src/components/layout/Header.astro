---
import Nav from './Nav.astro';
import { SITE_NAME } from '../../utils/constants';
---

<header class="site-header" id="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="logo" aria-label={`${SITE_NAME} — Inicio`}>
      <!-- TODO: reemplazar con SVG del logo cuando esté disponible -->
      <img
        src="/images/logo.png"
        alt="Logo Vitalidad Masculina"
        class="logo-image"
        width="100"
        height="100"
        loading="eager"
        decoding="async"
      />
      <span class="logo-text">
        <span class="logo-title">Vitalidad Masculina</span>
        <span class="logo-subtitle">Dr. Leandro Mateu</span>
      </span>
    </a>

    <!-- Nav desktop -->
    <div class="header-nav">
      <Nav />
    </div>

    <!-- CTA desktop -->
    <a href="/contacto" class="btn-cta">
      Solicitar consulta
    </a>

    <!-- Botón hamburguesa mobile -->
    <button
      class="mobile-menu-btn"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>
  </div>

  <!-- Menú mobile -->
  <div id="mobile-menu" class="mobile-menu" hidden>
    <nav aria-label="Navegación mobile">
      <ul role="list">
        <li><a href="/">Inicio</a></li>
        <li><a href="/disfuncion-erectil">Disfunción Eréctil</a></li>
        <li><a href="/eyaculacion-precoz">Eyaculación Precoz</a></li>
        <li><a href="/falta-de-deseo">Falta de Deseo</a></li>
        <li><a href="/terapia-hormonal">Terapia Hormonal</a></li>
        <li><a href="/urologia">Urología</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/sobre-mi">Sobre mí</a></li>
        <li><a href="/contacto" class="mobile-cta">Solicitar consulta</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(255, 255, 255, 0.88);
    border-bottom: 1px solid rgba(26, 42, 94, 0.12);
    backdrop-filter: blur(14px);
    /* Sombra animada via animations.css (.site-header) */
  }

  .site-header::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(201, 168, 76, 0.55) 50%, transparent 100%);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.65rem 1.5rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.88) 0%, rgba(247, 249, 253, 0.84) 100%);
    border: 1px solid rgba(26, 42, 94, 0.12);
    border-radius: 18px;
    box-shadow: 0 10px 26px rgba(26, 42, 94, 0.12);
    margin-top: 0.35rem;
    margin-bottom: 0.35rem;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-image {
    width: 6.75rem;
    height: 6.75rem;
    object-fit: contain;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-title {
    font-family: var(--font-heading);
    font-size: 1.06rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--color-navy);
  }

  .logo-subtitle {
    font-size: 0.72rem;
    color: #667085;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Nav + CTA desktop */
  .header-nav {
    flex: 1;
    display: flex;
    justify-content: center;
    padding: 0.34rem;
    background: rgba(26, 42, 94, 0.045);
    border: 1px solid rgba(26, 42, 94, 0.1);
    border-radius: 999px;
  }

  .btn-cta {
    display: inline-block;
    padding: 0.62rem 1.35rem;
    background-color: var(--color-gold);
    color: var(--color-white);
    font-weight: 700;
    font-size: 0.83rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: 0 8px 18px rgba(180, 143, 45, 0.28);
    transition: background-color 0.2s, transform 0.15s, box-shadow 0.2s;
    flex-shrink: 0;
  }

  .btn-cta:hover {
    background-color: #b79332;
    transform: translateY(-1px);
    box-shadow: 0 10px 22px rgba(180, 143, 45, 0.35);
  }

  /* Hamburguesa */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0.375rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    background: none;
    border: none;
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-navy);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* Mobile menu */
  .mobile-menu {
    background-color: var(--color-white);
    border-top: 1px solid var(--color-navy-light);
    padding: 1rem 1.5rem 1.5rem;
  }

  .mobile-menu ul {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-menu a {
    display: block;
    padding: 0.625rem 0.75rem;
    color: var(--color-navy);
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: background-color 0.15s;
  }

  .mobile-menu a:hover {
    background-color: var(--color-navy-light);
  }

  .mobile-cta {
    margin-top: 0.5rem;
    background-color: var(--color-gold) !important;
    color: var(--color-white) !important;
    text-align: center;
    font-weight: 600 !important;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .header-nav,
    .btn-cta {
      display: none;
    }

    .logo-image {
      width: 4.5rem;
      height: 4.5rem;
    }

    .logo-title {
      font-size: 0.95rem;
    }

    .logo-subtitle {
      display: none;
    }

    .header-inner {
      border-radius: 14px;
      padding: 0.52rem 0.8rem;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.hidden;
    if (menu) menu.hidden = isOpen;
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Abrir menú de navegación' : 'Cerrar menú de navegación');
  });
</script>
